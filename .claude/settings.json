{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "uv run python .claude/hooks/lint-check.py",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ]
  },
  "plansDirectory": "./docs/plans"
}
